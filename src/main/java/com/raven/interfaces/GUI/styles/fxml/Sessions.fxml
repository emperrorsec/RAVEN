<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      style="-fx-background-color:#1c1c1c;"
      spacing="0">

    <HBox styleClass="toolbar" alignment="CENTER_LEFT">
        <TextField fx:id="searchField"
                   promptText="Filter sessions..."
                   styleClass="input-field"
                   prefWidth="200"
                   HBox.hgrow="NEVER"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="refreshBtn"   text="Refresh"    styleClass="btn-default"/>
        <Button fx:id="executeBtn"   text="Execute"    styleClass="btn-accent"/>
        <Button fx:id="broadcastBtn" text="Broadcast"  styleClass="btn-default"/>
        <Button fx:id="killBtn"      text="Kill"       styleClass="btn-danger"/>
    </HBox>

    <HBox styleClass="cmd-bar" alignment="CENTER_LEFT">
        <Label text=">" styleClass="cmd-prompt"/>
        <TextField fx:id="srvInput"
                   promptText="sessions  |  status  |  stats  |  kill &lt;id&gt;  |  sysinfo &lt;id&gt;  |  exec &lt;id&gt; &lt;cmd&gt;  |  history [id] [limit]"
                   styleClass="input-field"
                   HBox.hgrow="ALWAYS"/>
        <Button fx:id="srvExecBtn" text="Run" styleClass="btn-accent"/>
    </HBox>

    <TableView fx:id="sessionTable"
               styleClass="session-table"
               VBox.vgrow="ALWAYS"/>
</VBox>
