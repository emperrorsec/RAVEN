<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      style="-fx-background-color:#1c1c1c;"
      spacing="0">

    <HBox styleClass="toolbar" alignment="CENTER_LEFT">
        <Label text="Session ID" styleClass="text-muted"/>
        <TextField fx:id="sessionIdField"
                   prefWidth="70"
                   styleClass="input-field"/>
        <Region style="-fx-background-color:#3d3d3d; -fx-pref-width:1; -fx-pref-height:18;"
                HBox.hgrow="NEVER"/>
        <Label fx:id="selectedAgentLabel"
               text="No session selected"
               styleClass="text-muted"
               HBox.hgrow="ALWAYS"/>
        <Button fx:id="clearBtn" text="Clear" styleClass="btn-flat"/>
    </HBox>

    <TextArea fx:id="terminalOutput"
              editable="false"
              styleClass="terminal-area"
              VBox.vgrow="ALWAYS"/>

    <HBox styleClass="cmd-bar" alignment="CENTER_LEFT">
        <Label text=">" styleClass="cmd-prompt"/>
        <TextField fx:id="cmdInputField"
                   promptText="Enter command..."
                   styleClass="input-field"
                   HBox.hgrow="ALWAYS"/>
        <Button fx:id="sendBtn" text="Send" styleClass="btn-accent"/>
    </HBox>
</VBox>
