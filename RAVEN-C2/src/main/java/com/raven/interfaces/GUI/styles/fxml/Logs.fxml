<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      style="-fx-background-color:#1c1c1c;"
      spacing="0">

    <HBox styleClass="toolbar" alignment="CENTER_RIGHT">
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="exportBtn" text="Export" styleClass="btn-outlined"/>
        <Button fx:id="clearBtn"  text="Clear"  styleClass="btn-danger"/>
    </HBox>

    <TextArea fx:id="logOutput"
              editable="false"
              styleClass="terminal-area"
              VBox.vgrow="ALWAYS"/>
</VBox>
